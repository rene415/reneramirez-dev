# reneramirez.dev — static serve via Caddy
:80 {
	root * /srv
	encode gzip zstd
	file_server

	# Long cache for hashed Astro assets
	@hashed path /_astro/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Short cache for HTML (so updates show quickly)
	@html {
		path *.html
		path /
	}
	header @html Cache-Control "public, max-age=300, must-revalidate"

	# Sensible defaults
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Pretty URLs + 404 fallback
	try_files {path} {path}/ /404.html
}
