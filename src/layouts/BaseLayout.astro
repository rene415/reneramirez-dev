---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Rene Ramirez',
  description = 'Rene Ramirez. Personal site — projects, music, photography.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#f4efe5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#08041a" media="(prefers-color-scheme: dark)" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;600&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&family=VT323&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/logo/rene%20Logo.PNG" />
    <link rel="apple-touch-icon" href="/logo/rene%20Logo.PNG" />
  </head>
  <body data-mode="day">
    <slot />
  </body>
</html>
