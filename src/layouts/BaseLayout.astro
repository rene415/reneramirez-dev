---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Rene Ramirez',
  description = 'Rene Ramirez. Personal site — projects, music, photography.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#f4efe5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#08041a" media="(prefers-color-scheme: dark)" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;600&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500&family=VT323&display=swap"
      rel="stylesheet"
    />
    <!-- favicon set: browsers pick the best match. ICO is a multi-size
         bundle (16/32/48/64/128/256) for legacy + Windows; PNGs are
         what modern browsers prefer; apple-touch-icon is for iOS
         home-screen bookmarks. All generated from /logo/rene Logo.PNG. -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body data-mode="day">
    <slot />
  </body>
</html>
