---
const lines = [
  { k: 'Reading',  v: 'Stephen King — 11/22/63',                  note: 'just picked up an e-reader' },
  { k: 'Learning', v: 'AI · finance · whatever else won\'t stop',  note: null },
  { k: 'Building', v: 'this site. the rest is a moving target',    note: null },
  { k: 'Located',  v: 'SF Bay Area',                                note: null },
];
const aside = 'lost in the amount of knowledge I tie myself in.';
---
<section class="currently">
  <header class="section-head">
    <span class="section-num">03</span>
    <h2 class="section-title">Currently</h2>
  </header>
  <dl class="list">
    {lines.map(({ k, v, note }) => (
      <div class="row">
        <dt>{k}</dt>
        <dd>
          <span class="val">{v}</span>
          {note && <span class="note">— {note}</span>}
        </dd>
      </div>
    ))}
  </dl>
  <p class="aside">{aside}</p>
</section>

<style>
  .currently { padding: 5rem 0; border-bottom: 1px solid var(--line); }
  .section-head { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 2.5rem; }
  .section-num {
    font-family: 'VT323', monospace; font-size: 1rem; color: var(--muted); letter-spacing: 0.1em;
  }
  .section-title {
    font-family: 'IBM Plex Serif', Georgia, serif;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 600; letter-spacing: -0.02em;
  }
  .list { display: grid; gap: 1rem; max-width: 44rem; }
  .row {
    display: grid; grid-template-columns: 8rem 1fr;
    gap: 1.5rem; padding: 0.85rem 0;
    border-top: 1px solid var(--line);
    font-size: 0.98rem;
  }
  .row:last-child { border-bottom: 1px solid var(--line); }
  dt {
    font-family: 'VT323', monospace;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .val { color: var(--fg); }
  .note { color: var(--muted); font-style: italic; margin-left: 0.25rem; }

  .aside {
    margin-top: 2rem;
    color: var(--muted);
    font-style: italic;
    max-width: 44rem;
    font-size: 0.95rem;
  }
</style>
