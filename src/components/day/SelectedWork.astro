---
import BrowserFrame from '../BrowserFrame.svelte';
import { projects } from '../../data/projects';
---
<section class="work" id="work">
  <header class="section-head">
    <span class="section-num">01</span>
    <h2 class="section-title">Selected work</h2>
    <span class="count">{projects.length} {projects.length === 1 ? 'project' : 'projects'}</span>
  </header>

  {projects.length === 0 ? (
    <p class="empty">
      No projects yet. Add entries in <code>src/data/projects.ts</code>.
    </p>
  ) : (
    <ol class="projects">
      {projects.map((p, i) => (
        <li class="project">
          <header class="project-head">
            <span class="idx">{String(i + 1).padStart(2, '0')}</span>
            <div class="meta">
              <h3 class="name">{p.name}</h3>
              <div class="sub">
                <span class="role">{p.role}</span>
                <span class="dot" aria-hidden="true">·</span>
                <span class="year">{p.year}</span>
              </div>
            </div>
          </header>
          {p.blurb && <p class="blurb">{p.blurb}</p>}
          <BrowserFrame client:visible src={p.url} displayUrl={p.displayUrl} />
        </li>
      ))}
    </ol>
  )}
</section>

<style>
  .work {
    padding: 5rem 0;
    border-bottom: 1px solid var(--line);
  }
  .section-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  .section-num {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }
  .section-title {
    font-family: 'IBM Plex Serif', Georgia, serif;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .count {
    margin-left: auto;
    font-family: 'VT323', monospace;
    font-size: 0.95rem;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .projects {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4.5rem;
  }
  .project {
    display: grid;
    gap: 0.9rem;
  }

  /* header row: numbered index + project name/meta */
  .project-head {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    align-items: baseline;
  }
  .project-head .idx {
    font-family: 'VT323', monospace;
    font-size: 1.2rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    line-height: 1;
  }
  .project-head .name {
    font-family: 'IBM Plex Serif', Georgia, serif;
    font-size: clamp(1.4rem, 3.2vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .project-head .sub {
    margin-top: 0.4rem;
    font-family: 'VT323', monospace;
    font-size: 0.95rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .project-head .dot { color: var(--accent); }

  .blurb {
    grid-column: 2 / -1;
    margin-left: calc(3rem + 1rem); /* align under the name (idx col + gap) */
    color: var(--muted);
    line-height: 1.6;
    max-width: 56ch;
    font-size: 1rem;
  }

  /* mobile: drop the indented blurb */
  @media (max-width: 540px) {
    .project-head { grid-template-columns: 1fr; gap: 0.3rem; }
    .blurb { margin-left: 0; }
  }

  .empty {
    color: var(--muted);
    padding: 2rem;
    border: 1px dashed var(--line);
    border-radius: 4px;
    text-align: center;
    font-family: 'VT323', monospace;
    letter-spacing: 0.05em;
  }
  .empty code {
    background: rgba(0, 0, 0, 0.05);
    padding: 1px 6px;
    border-radius: 2px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
  }
</style>
