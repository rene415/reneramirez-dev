---
import BaseLayout from '../layouts/BaseLayout.astro';
import Intro from '../components/day/Intro.astro';
import Timeline from '../components/day/Timeline.astro';
import SelectedWork from '../components/day/SelectedWork.astro';
import Professional from '../components/day/Professional.astro';
import Currently from '../components/day/Currently.astro';
import Contact from '../components/day/Contact.astro';
import FooterDay from '../components/day/FooterDay.astro';
import SoundToggle from '../components/SoundToggle.svelte';
import NightShell from '../components/night/NightShell.svelte';
---
<BaseLayout title="Rene Ramirez">
  <SoundToggle client:load />

  <!-- ── A-side (default) ───────────────────────────────────── -->
  <div class="day-shell">
    <div class="container">
      <Intro />
      <Timeline />
      <SelectedWork />
      <Professional />
      <Currently />
      <Contact />
      <FooterDay />
    </div>
  </div>

  <!-- ── B-side (hidden in CSS by default, swapped via [data-mode]) -->
  <div class="night-shell">
    <NightShell client:visible />
  </div>
</BaseLayout>

<style>
  .container {
    width: 100%;
    /* Full width — no max-width cap. Side padding scales 1.5rem → 4rem
       so the layout breathes on huge displays. Section content
       (bio paragraphs, timeline track, contact rows, etc.) stays
       readable via its own max-width:56ch / 720px constraints. */
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }
  .day-shell, .night-shell {
    transition: opacity 600ms ease;
  }
  /* default state — Day visible, Night hidden */
  :global([data-mode='day']) .day-shell    { opacity: 1; }
  :global([data-mode='day']) .night-shell  { display: none; }
  :global([data-mode='night']) .day-shell  { display: none; }
  :global([data-mode='night']) .night-shell { opacity: 1; }
</style>
